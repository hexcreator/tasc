    "solana:build-sbf": "node bin/build-solana-sbf.js",
    "solana:deploy-plan": "node bin/deploy-solana-program.js plan",
    "solana:deploy": "node bin/deploy-solana-program.js deploy",
    "solana:live-intent": "node bin/create-solana-live-intent.js",
    "solana:fund-plan": "node bin/run-solana-fund.js plan",
