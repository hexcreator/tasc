    "solana:create-wallets": "node bin/run-solana-devnet.js create-wallets",
    "solana:balances": "node bin/run-solana-devnet.js balances",
    "solana:airdrop:buyer": "node bin/run-solana-devnet.js airdrop --role buyer --sol 1",
    "solana:airdrop:all": "node bin/run-solana-devnet.js airdrop --role all --sol 1",
    "solana:fund-roles": "node bin/run-solana-devnet.js fund-roles --from buyer --sol 0.01",
