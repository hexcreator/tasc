{
  "name": "global-tasc",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "license": "Apache-2.0",
  "description": "Seed prototype for a decentralized instant micro-work task protocol.",
  "scripts": {
    "demo": "npm run compile:example && npm run verify:example && npm run demo:market && npm run validate:indexer && npm run validate:web && npm run validate:solana-spl-escrow && npm run validate:solana-lifecycle-tx && npm run validate:solana-spl-settlement && npm run validate:solana-settlement-scan && npm run validate:solana-proof-runner",
    "devnet:proof": "npm run solana:fund-spl-plan:live && npm run index:admit-solana-spl-live",
    "prove:solana-devnet:plan": "node bin/prove-solana-devnet.js plan",
    "prove:solana-devnet": "node bin/prove-solana-devnet.js run",
    "compile:example": "node bin/tasclang.js compile examples/summarize_url.tasc",
    "verify:example": "node bin/tascverify.js examples/summarize_url.tasc examples/submissions/summarize_url.pass.md --input url=https://docs.cdp.coinbase.com/x402/welcome --ledger examples/ledger.json",
    "demo:market": "node bin/tascmarket.js demo examples/summarize_url.tasc examples/submissions/summarize_url.pass.md --input url=https://docs.cdp.coinbase.com/x402/welcome --ledger examples/ledger.json",
    "validate:evm": "node bin/validate-evm.js",
    "intent:example": "node bin/tascintent.js create examples/summarize_url.tasc --buyer 0xf39fd6e51aad88f6f4ce6ab8827279cfffb92266 --escrow 0x2222222222222222222222222222222222222222 --token 0x3333333333333333333333333333333333333333 --verifier 0x4444444444444444444444444444444444444444 --chain-id 84532 --nonce 1 --now 1800000000",
    "intent:write-example": "node bin/tascintent.js create examples/summarize_url.tasc --buyer 0xf39fd6e51aad88f6f4ce6ab8827279cfffb92266 --escrow 0x2222222222222222222222222222222222222222 --token 0x3333333333333333333333333333333333333333 --verifier 0x4444444444444444444444444444444444444444 --chain-id 84532 --nonce 1 --now 1800000000 --out examples/intents/summarize_url.intent.json",
    "validate:intent": "node bin/validate-intent.js",
    "sign:example": "node bin/tascsign.js sign examples/intents/summarize_url.intent.json --test-key hardhat0",
    "sign:write-example": "node bin/tascsign.js sign examples/intents/summarize_url.intent.json --test-key hardhat0 --out examples/signatures/summarize_url.signature.json",
    "validate:signature": "node bin/validate-signature.js",
    "compile:solidity": "node bin/compile-solidity.js",
    "local-escrow:plan": "node bin/run-local-escrow.js plan",
    "local-escrow:flow": "node bin/run-local-escrow.js flow",
    "base:plan": "node bin/run-base-sepolia.js plan",
    "base:flow": "node bin/run-base-sepolia.js flow",
    "base:flow:handoff": "node bin/run-base-sepolia.js flow --handoff examples/testnet/base-sepolia.handoff.json",
    "validate:base-sepolia": "node bin/validate-base-sepolia.js",
    "validate:testnet-handoff": "node bin/validate-testnet-handoff.js",
