# Copy this file to .env.solana-mainnet.local for the first real USDC run.
# Keep .env.solana-mainnet.local private. It is ignored by git.
# Do not put private keys, seed phrases, mnemonics, or keypair JSON in this file.

# Mainnet RPC. The tools persist only the host, never the full URL.
SOLANA_MAINNET_RPC_URL=
SOLANA_MAINNET_EXPECTED_GENESIS_HASH=

# Reviewed/deployed Global Tasc mainnet program and verified mainnet USDC mint.
GLOBAL_TASC_SOLANA_MAINNET_PROGRAM_ID=
GLOBAL_TASC_SOLANA_MAINNET_USDC_MINT=

# Public role wallets. These should be distinct for a real income proof.
GLOBAL_TASC_SOLANA_MAINNET_BUYER_ADDRESS=
GLOBAL_TASC_SOLANA_MAINNET_WORKER_ADDRESS=
GLOBAL_TASC_SOLANA_MAINNET_VERIFIER_ADDRESS=

# SPL USDC token accounts.
# Buyer account must hold at least 10000000 base units (10 USDC).
# Worker account receives the release payout.
GLOBAL_TASC_SOLANA_MAINNET_BUYER_USDC_TOKEN_ACCOUNT=
GLOBAL_TASC_SOLANA_MAINNET_WORKER_USDC_TOKEN_ACCOUNT=
